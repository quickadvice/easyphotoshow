<UserControl x:Class="EasyPhotoShow.App.Views.PlaybackView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EasyPhotoShow.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:PlaybackViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded">

    <UserControl.Resources>
        <!-- Warm charcoal palette for the dark control bar. -->
        <Color x:Key="StageColor">#1A1714</Color>
        <Color x:Key="ChromeColor">#252220</Color>
        <Color x:Key="ChromeMutedColor">#3A3531</Color>
        <Color x:Key="ChromeTextColor">#EDE4D2</Color>
        <Color x:Key="ChromeMutedTextColor">#8E867A</Color>

        <SolidColorBrush x:Key="StageBrush" Color="{StaticResource StageColor}" />
        <SolidColorBrush x:Key="ChromeBrush" Color="{StaticResource ChromeColor}" />
        <SolidColorBrush x:Key="ChromeMutedBrush" Color="{StaticResource ChromeMutedColor}" />
        <SolidColorBrush x:Key="ChromeTextBrush" Color="{StaticResource ChromeTextColor}" />
        <SolidColorBrush x:Key="ChromeMutedTextBrush" Color="{StaticResource ChromeMutedTextColor}" />

        <!-- Playback button: soft pill on dark chrome. Consistent with the app's warmth without
             competing with the slideshow itself. -->
        <Style x:Key="PlaybackButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource ChromeTextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="18,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource ChromeMutedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary playback action (Play/Pause) — warm accent so it reads as the main control. -->
        <Style x:Key="PlaybackPrimaryButton" TargetType="Button" BasedOn="{StaticResource PlaybackButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slim slider with circular accent thumb. Avoids the default Windows tick marks
             and chunky thumb that ruin the calm playback feel. -->
        <Style x:Key="PlaybackSlider" TargetType="Slider">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center" Height="22">
                            <Border Height="4"
                                    Background="{StaticResource ChromeMutedBrush}"
                                    CornerRadius="2"
                                    VerticalAlignment="Center" />
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="{StaticResource AccentBrush}"
                                                        CornerRadius="2" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="White"
                                                         Stroke="{StaticResource AccentBrush}"
                                                         StrokeThickness="2" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource StageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <MediaElement x:Name="Media"
                      Grid.Row="0"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Stop"
                      ScrubbingEnabled="True"
                      Stretch="Uniform"
                      MediaOpened="OnMediaOpened"
                      MediaEnded="OnMediaEnded" />

        <Border Grid.Row="1" Background="{StaticResource ChromeBrush}" Padding="0">
            <StackPanel>
                <!-- Position scrubber stretches across the full width so it's the dominant control -->
                <Slider x:Name="Position"
                        Style="{StaticResource PlaybackSlider}"
                        Margin="28,18,28,4"
                        Minimum="0" Maximum="1" Value="0"
                        Thumb.DragStarted="OnSliderDragStarted"
                        Thumb.DragCompleted="OnSliderDragCompleted"
                        PreviewMouseLeftButtonUp="OnSliderClick" />

                <Grid Margin="24,8,24,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="PlayPauseBtn" Grid.Column="0"
                            Style="{StaticResource PlaybackPrimaryButton}"
                            Content="Pause"
                            Click="OnPlayPause"
                            Margin="0,0,8,0" />

                    <Button Grid.Column="1"
                            Style="{StaticResource PlaybackButton}"
                            Content="Replay"
                            Click="OnReplay"
                            Margin="0,0,16,0" />

                    <TextBlock x:Name="TimeText" Grid.Column="2"
                               Foreground="{StaticResource ChromeMutedTextBrush}"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Text="0:00 / 0:00" />

                    <StackPanel Grid.Column="4" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="Volume"
                                   Foreground="{StaticResource ChromeMutedTextBrush}"
                                   VerticalAlignment="Center" Margin="0,0,12,0" FontSize="13" />
                        <Slider x:Name="VolumeSlider"
                                Style="{StaticResource PlaybackSlider}"
                                Width="120" Height="22"
                                Minimum="0" Maximum="1" Value="0.8"
                                ValueChanged="OnVolumeChanged" />
                    </StackPanel>

                    <Button x:Name="FullscreenBtn" Grid.Column="5"
                            Style="{StaticResource PlaybackButton}"
                            Content="Fullscreen"
                            Click="OnFullscreen"
                            Margin="0,0,8,0" />

                    <Button Grid.Column="6"
                            Style="{StaticResource PlaybackButton}"
                            Content="Close"
                            Click="OnClose" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
