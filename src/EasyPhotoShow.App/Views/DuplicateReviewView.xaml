<UserControl x:Class="EasyPhotoShow.App.Views.DuplicateReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EasyPhotoShow.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:DuplicateReviewViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,0,1"
                Padding="48,32">
            <Grid MaxWidth="1100" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource H1}" Text="Review Similar Photos" />
                    <TextBlock Style="{StaticResource Lead}"
                               Text="{Binding SummaryText}" />
                    <TextBlock Style="{StaticResource Subtle}" Margin="0,4,0,0"
                               Text="{Binding ExactCopyNote}"
                               Visibility="{Binding ExactCopyNote, Converter={StaticResource NullToVisibility}}" />
                    <TextBlock Style="{StaticResource Subtle}" Margin="0,8,0,0"
                               Text="Recommended photos are already selected. Review and adjust if needed." />
                    <TextBlock Style="{StaticResource Subtle}" Margin="0,4,0,0"
                               Text="Groups may include burst shots, re-exports, or photos that look nearly identical. Review and keep the ones you want." />
                    <TextBlock Style="{StaticResource Subtle}" Margin="0,4,0,0"
                               Text="Unselected photos move to a PotentialDuplicates folder — nothing is deleted." />
                </StackPanel>

                <Button Grid.Column="1" Style="{StaticResource PrimaryButton}"
                        Content="{Binding UseRecommendedChoicesLabel}"
                        VerticalAlignment="Center" Margin="32,0,0,0"
                        Command="{Binding UseRecommendedChoicesCommand}" />
            </Grid>
        </Border>

        <ScrollViewer x:Name="GroupsScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="48,24">
            <ItemsControl ItemsSource="{Binding CurrentPageGroups}" MaxWidth="1100" HorizontalAlignment="Center">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,16" Padding="20,16">
                            <ItemsControl ItemsSource="{Binding Photos}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,12,12" Padding="10"
                                                BorderThickness="2"
                                                CornerRadius="10">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                    <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRecommended}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Width="232">
                                                <!-- Soft placeholder rectangle underneath the Image. The Image binds to
                                                     Thumbnail (BitmapSource?) which is null until the background decode
                                                     completes — the rectangle shows through until then, so the page
                                                     doesn't flash empty during load. -->
                                                <Grid Width="212" Height="159" HorizontalAlignment="Center">
                                                    <Rectangle Fill="{StaticResource BorderSoftBrush}"
                                                               RadiusX="4" RadiusY="4" />
                                                    <Image Source="{Binding Thumbnail}"
                                                           Stretch="Uniform" />
                                                </Grid>

                                                <Border Background="{StaticResource AccentBrush}"
                                                        CornerRadius="10" Padding="10,3"
                                                        HorizontalAlignment="Left" Margin="0,8,0,0"
                                                        Visibility="{Binding IsRecommended, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="Recommended" Foreground="White"
                                                               FontSize="11" FontWeight="SemiBold" />
                                                </Border>

                                                <TextBlock Style="{StaticResource Body}" FontSize="13"
                                                           Margin="0,6,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding DisplayName}" />
                                                <TextBlock Style="{StaticResource Caption}"
                                                           Text="{Binding Dimensions}" />

                                                <CheckBox Content="Use this photo"
                                                          Margin="0,10,0,0"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,1,0,0"
                Padding="48,20">
            <Grid MaxWidth="1100" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource QuietButton}" Content="Previous"
                            Command="{Binding PrevPageCommand}" />
                    <TextBlock Style="{StaticResource Subtle}" Margin="16,0" VerticalAlignment="Center"
                               FontSize="13" Text="{Binding PageText}" />
                    <Button Style="{StaticResource QuietButton}" Content="Next"
                            Command="{Binding NextPageCommand}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,12,0" VerticalAlignment="Center">
                        <Button Style="{StaticResource SecondaryButton}" Content="Include All Photos"
                                ToolTip="Keeps every photo and skips the duplicate folder."
                                Command="{Binding SkipReviewCommand}" />
                        <TextBlock Style="{StaticResource Caption}"
                                   Text="Keeps every photo and skips the duplicate folder."
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                    <Button Style="{StaticResource PrimaryButton}" Content="Continue"
                            Command="{Binding ContinueCommand}"
                            VerticalAlignment="Top" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
