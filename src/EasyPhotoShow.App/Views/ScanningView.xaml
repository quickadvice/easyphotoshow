<UserControl x:Class="EasyPhotoShow.App.Views.ScanningView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EasyPhotoShow.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:ScanningViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <!-- ScrollViewer wraps the card so the exact-copy section can extend the layout
         on small windows without compressing the progress bar / messaging area above. -->
    <ScrollViewer Background="{StaticResource BackgroundBrush}"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Border Style="{StaticResource Card}" Padding="48,40,48,32"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="720" MinWidth="500" Margin="24,32">
            <StackPanel>
                <TextBlock Style="{StaticResource H1}" HorizontalAlignment="Center"
                           Text="One moment..." />
                <TextBlock Style="{StaticResource Lead}" HorizontalAlignment="Center"
                           Margin="0,4,0,0" TextAlignment="Center"
                           Text="{Binding StatusText}" />
                <TextBlock Style="{StaticResource Subtle}" HorizontalAlignment="Center"
                           Margin="0,8,0,0" FontSize="13" TextAlignment="Center"
                           Text="{Binding SecondaryStatus}"
                           Visibility="{Binding SecondaryStatus, Converter={StaticResource NullToVisibility}}" />

                <!-- Determinate during Phase 3 (dHash, total known); indeterminate during
                     Phase 1 (folder walk) and Phase 2 (SHA-256). Same blue-on-beige visual
                     as the render screen so the user sees a consistent progress style. -->
                <Grid Margin="0,28,0,0" Height="12">
                    <Border x:Name="ScanProgressTrack"
                            Background="{StaticResource ProgressTrackBrush}"
                            CornerRadius="6"
                            HorizontalAlignment="Stretch"
                            ClipToBounds="True"
                            Visibility="{Binding IsProgressDeterminate, Converter={StaticResource BoolToVisibility}}">
                        <Border HorizontalAlignment="Left"
                                VerticalAlignment="Stretch"
                                Background="{StaticResource ProgressFillBrush}"
                                CornerRadius="6">
                            <Border.Width>
                                <MultiBinding Converter="{StaticResource FractionToWidth}">
                                    <Binding Path="ProgressFraction" />
                                    <Binding Path="ActualWidth" ElementName="ScanProgressTrack" />
                                </MultiBinding>
                            </Border.Width>
                        </Border>
                    </Border>
                    <ProgressBar IsIndeterminate="True"
                                 Foreground="{StaticResource ProgressFillBrush}"
                                 Background="{StaticResource ProgressTrackBrush}"
                                 BorderThickness="0"
                                 Visibility="{Binding IsProgressDeterminate, Converter={StaticResource InverseBoolToVisibility}}" />
                </Grid>

                <TextBlock Style="{StaticResource Caption}" HorizontalAlignment="Center"
                           Margin="0,20,0,0" TextAlignment="Center"
                           Text="{Binding UnsupportedNote}"
                           Visibility="{Binding UnsupportedNote, Converter={StaticResource NullToVisibility}}" />

                <!-- Exact copy section — only appears once the first ExactOnly group is found.
                     Sits below the progress UI and shows a running count of exact duplicates
                     handled so far (no thumbnails — text-only reassurance). -->
                <StackPanel Margin="0,28,0,0"
                            Visibility="{Binding ShowExactCopySection, Converter={StaticResource BoolToVisibility}}">

                    <Border Background="{StaticResource BorderSoftBrush}" Height="1" Margin="0,0,0,20" />

                    <!-- Running counter. Plain-English wording, accent-tinted reassurance that
                         exact duplicates are being handled safely as the scan progresses. -->
                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center"
                               Foreground="{StaticResource AccentHoverBrush}"
                               FontSize="15" FontWeight="SemiBold"
                               Text="{Binding ExactCopyCount, StringFormat='{}{0} exact duplicate files handled so far'}" />
                </StackPanel>

                <!-- Completion message — visible only during the 1.5 s beat between work end and
                     navigation. StatusText is cleared by the view model when this is set, so the
                     Lead text above goes blank and this message stands alone. -->
                <TextBlock HorizontalAlignment="Center" TextAlignment="Center"
                           Foreground="{StaticResource AccentHoverBrush}"
                           FontSize="17" FontWeight="SemiBold"
                           Margin="0,28,0,0"
                           Text="{Binding CompletionMessage}"
                           Visibility="{Binding CompletionMessage, Converter={StaticResource NullToVisibility}}" />
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
