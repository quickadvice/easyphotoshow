<UserControl x:Class="EasyPhotoShow.App.Views.SlideshowCreationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EasyPhotoShow.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:SlideshowCreationViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <UserControl.Resources>
        <!-- Mode-selector pill base. Active state is applied per-instance below (the active
             condition differs between the two pills), keying off the section's IsImageMode /
             IsTextMode. Warm-gold active fill — never brand blue. -->
        <Style x:Key="ModePillBase" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- One opening/closing slide section. Auto-applied to ContentControls bound to a
             SlideSectionViewModel, so the opener and closer share one layout definition. -->
        <DataTemplate DataType="{x:Type vm:SlideSectionViewModel}">
            <StackPanel>
                <TextBlock Style="{StaticResource Caption}" Text="{Binding SectionTitle}" />
                <CheckBox Margin="0,6,0,0" Content="{Binding EnableLabel}" IsChecked="{Binding IsEnabled}" />

                <StackPanel Margin="0,12,0,0"
                            Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVisibility}}">

                    <!-- Two-pill segmented mode selector -->
                    <Border HorizontalAlignment="Left" CornerRadius="8" ClipToBounds="True"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Custom Image" Command="{Binding UseImageModeCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModePillBase}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsImageMode}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Text" Command="{Binding UseTextModeCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModePillBase}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTextMode}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Custom Image mode -->
                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0"
                                Visibility="{Binding IsImageMode, Converter={StaticResource BoolToVisibility}}">
                        <Button Style="{StaticResource SecondaryButton}" Content="Choose Photo..."
                                Padding="18,10" VerticalAlignment="Center"
                                Command="{Binding ChooseImageCommand}" />
                        <Rectangle Width="80" Height="60" Margin="12,0,0,0" RadiusX="6" RadiusY="6"
                                   Stroke="{StaticResource BorderBrush}" StrokeThickness="1"
                                   StrokeDashArray="3,2" Fill="Transparent" VerticalAlignment="Center"
                                   Visibility="{Binding HasCustomImage, Converter={StaticResource InverseBoolToVisibility}}" />
                        <Border Width="80" Height="60" Margin="12,0,0,0" CornerRadius="6" ClipToBounds="True"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasCustomImage, Converter={StaticResource BoolToVisibility}}">
                            <Image Stretch="UniformToFill"
                                   Source="{Binding CustomImagePath, Converter={StaticResource Thumb160}}" />
                        </Border>
                    </StackPanel>

                    <!-- Text mode -->
                    <StackPanel Margin="0,14,0,0"
                                Visibility="{Binding IsTextMode, Converter={StaticResource BoolToVisibility}}">
                        <TextBox MaxLength="120" TextWrapping="Wrap" AcceptsReturn="False" MinHeight="64"
                                 VerticalContentAlignment="Top"
                                 Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock HorizontalAlignment="Right" Margin="0,4,0,0" FontSize="12"
                                   Text="{Binding CharCountText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNearLimit}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Background swatches: black | white. Selected gets a warm-gold ring. -->
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Border Width="32" Height="32" CornerRadius="6" Background="#000000"
                                    Cursor="Hand" BorderThickness="2">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding SelectBlackCommand}" />
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBlackSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <Border Width="32" Height="32" CornerRadius="6" Background="#FFFFFF"
                                    Cursor="Hand" Margin="10,0,0,0" BorderThickness="2">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding SelectWhiteCommand}" />
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsWhiteSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </StackPanel>

                        <!-- Live preview (updates on every keystroke via PreviewText binding) -->
                        <Border Width="320" Height="180" Margin="0,12,0,0" CornerRadius="4"
                                HorizontalAlignment="Left" ClipToBounds="True"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Background="{Binding PreviewBackgroundBrush}">
                            <TextBlock Text="{Binding PreviewText}" Foreground="{Binding PreviewForegroundBrush}"
                                       FontSize="22" TextWrapping="Wrap" TextAlignment="Center"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20" />
                        </Border>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
    <ScrollViewer Background="{StaticResource BackgroundBrush}" VerticalScrollBarVisibility="Auto">
        <Grid Margin="40,28,40,32" MaxWidth="780" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Style="{StaticResource H1}" Text="Your slideshow" Margin="0,0,0,4" />
                <TextBlock Style="{StaticResource Lead}" Margin="0,0,0,20"
                           Text="Choose how it should look and where to save it." />

                <Border Style="{StaticResource Card}" Margin="0,0,0,14" Padding="28,22">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H2}" Text="Summary" Margin="0,0,0,4" />
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1.4*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource Caption}" Text="PHOTOS" />
                                <TextBlock Style="{StaticResource Body}" FontSize="24" FontWeight="SemiBold"
                                           Margin="0,4,0,0" Text="{Binding PhotoCount}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Style="{StaticResource Caption}" Text="SECONDS PER PHOTO" />
                                <!-- Spinner: ▼ / TextBox / ▲. Keyboard up/down arrows wired in code-behind.
                                     Range clamp (1.0–20.0) and 0.5 step both live in the VM
                                     (OnSecondsPerPhotoChanged + the new SpinSecondsPerPhoto helper). -->
                                <Grid Margin="0,4,0,0" HorizontalAlignment="Left">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource QuietButton}"
                                            Content="▼" Padding="10,4" MinWidth="32"
                                            Click="SecondsPerPhotoDownClick" />
                                    <TextBox Grid.Column="1" x:Name="SecondsPerPhotoBox"
                                             Width="64" Margin="4,0,4,0"
                                             VerticalContentAlignment="Center" TextAlignment="Center"
                                             KeyDown="SecondsPerPhotoBox_KeyDown"
                                             LostFocus="SecondsPerPhotoBox_LostFocus"
                                             Text="{Binding SecondsPerPhoto, UpdateSourceTrigger=LostFocus, StringFormat=N1}" />
                                    <Button Grid.Column="2" Style="{StaticResource QuietButton}"
                                            Content="▲" Padding="10,4" MinWidth="32"
                                            Click="SecondsPerPhotoUpClick" />
                                </Grid>
                            </StackPanel>

                            <Border Grid.Column="2"
                                    Background="{StaticResource AccentSoftBrush}"
                                    CornerRadius="10" Padding="18,12" Margin="12,0,0,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Caption}" Text="ESTIMATED RUNTIME"
                                               Foreground="{StaticResource AccentHoverBrush}" />
                                    <TextBlock FontSize="30" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,4,0,0" Text="{Binding EstimatedRuntime}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,14" Padding="28,22">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H2}" Text="Style" Margin="0,0,0,4" />
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource Caption}" Text="PHOTO ORDER" />
                                <ComboBox Margin="0,6,0,0" ItemsSource="{Binding OrderingOptions}"
                                          SelectedItem="{Binding Ordering}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource Caption}" Text="TRANSITION" />
                                <ComboBox Margin="0,6,0,0" ItemsSource="{Binding TransitionOptions}"
                                          SelectedItem="{Binding Transition}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,14" Padding="28,22">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H2}" Text="Music" Margin="0,0,0,4" />
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource Caption}" Text="CHOOSE A TRACK" />
                                <ComboBox Margin="0,6,0,0" ItemsSource="{Binding MusicOptions}"
                                          SelectedItem="{Binding MusicPreset}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                <Button Style="{StaticResource SecondaryButton}"
                                        Content="Upload MP3"
                                        Padding="18,10"
                                        Command="{Binding ChooseCustomMusicCommand}"
                                        Visibility="{Binding IsCustomMusicSelected, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Style="{StaticResource Subtle}" FontSize="13" Margin="0,10,0,0"
                                   Text="{Binding CustomMusicDisplay}"
                                   Visibility="{Binding CustomMusicDisplay, Converter={StaticResource NullToVisibility}}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,14" Padding="28,22">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H2}" Text="Opening &amp; Closing Slides" Margin="0,0,0,4" />
                        <ContentControl Content="{Binding Opener}" Margin="0,8,0,0" />
                        <Border Height="1" Background="{StaticResource BorderSoftBrush}" Margin="0,16" />
                        <ContentControl Content="{Binding Closer}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,14" Padding="28,22">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H2}" Text="Save your slideshow" Margin="0,0,0,4" />
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Style="{StaticResource Caption}" Text="NAME" />
                                <TextBox Margin="0,6,0,0"
                                         Text="{Binding SlideshowName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource Caption}" Text="FOLDER" />
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox IsReadOnly="True" Text="{Binding SaveFolder}" />
                                    <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"
                                            Padding="18,10"
                                            Content="Browse"
                                            Command="{Binding ChooseSaveFolderCommand}" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource AccentSoftBrush}"
                        BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                        CornerRadius="10" Padding="16,12" Margin="0,0,0,14"
                        Visibility="{Binding TrialWarning, Converter={StaticResource NullToVisibility}}">
                    <TextBlock Style="{StaticResource Body}" Foreground="{StaticResource TextPrimaryBrush}"
                               Text="{Binding TrialWarning}" />
                </Border>

                <TextBlock Style="{StaticResource Subtle}" FontSize="13" Margin="0,0,0,12"
                           Text="{Binding SlidesRemovalNote}"
                           Visibility="{Binding SlidesRemovalNote, Converter={StaticResource NullToVisibility}}" />

                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource QuietButton}" Content="Back"
                            Command="{Binding BackCommand}" />
                    <Button Grid.Column="2" Style="{StaticResource PrimaryButton}"
                            Content="Create Slideshow"
                            Command="{Binding CreateCommand}" />
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
