<UserControl x:Class="EasyPhotoShow.App.Views.CompletionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EasyPhotoShow.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:CompletionViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Background="{StaticResource BackgroundBrush}">
        <Border Style="{StaticResource Card}" Padding="56,48"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="620">
            <StackPanel>
                <TextBlock Style="{StaticResource H1}" HorizontalAlignment="Center"
                           TextAlignment="Center" Text="{Binding Headline}" />
                <TextBlock Style="{StaticResource Lead}" HorizontalAlignment="Center"
                           TextAlignment="Center" Margin="0,4,0,36"
                           Text="{Binding Subhead}" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Style="{StaticResource PrimaryButton}" Content="View Slideshow"
                            Command="{Binding ViewSlideshowCommand}" Margin="0,0,12,0" />
                    <Button Style="{StaticResource SecondaryButton}" Content="Open Folder"
                            Command="{Binding OpenFolderCommand}" Margin="0,0,12,0" />
                    <Button Style="{StaticResource SecondaryButton}" Content="Done"
                            Command="{Binding DoneCommand}" />
                </StackPanel>
                <StackPanel Margin="0,36,0,0">
                    <TextBlock Style="{StaticResource Caption}" HorizontalAlignment="Center"
                               Text="SAVED TO" />
                    <TextBlock Style="{StaticResource Subtle}" FontSize="13"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0,4,0,0" TextWrapping="Wrap"
                               Text="{Binding OutputPath}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
