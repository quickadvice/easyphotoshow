# Build output
bin/
obj/

# Visual Studio user files
*.user
*.suo
.vs/

# FFmpeg binaries (large, not ours to redistribute via source control)
src/EasyPhotoShow.App/tools/ffmpeg/

# Music MP3s (large binary assets, distributed via installer only) — covers the preset
