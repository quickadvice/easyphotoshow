*.mp3

# Error logs saved by the app
Errors/

# Claude Code session memory
.claude/

# Installer build output (generated artifacts)
installer/Output/

# Release publish output (generated; distributed via installer, not source control)
publish/

# OS
Thumbs.db
Desktop.ini
.DS_Store
